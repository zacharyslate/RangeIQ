# Optional environment overrides for the RangeIQ systemd service.
# Copy to /etc/rangeiq/rangeiq.env and edit as needed.

NDVI_PROVIDER=earth_search_stac
EARTH_SEARCH_STAC_URL=https://earth-search.aws.element84.com/v1
NDVI_DEFAULT_COLLECTION=sentinel-2-l2a
NDVI_CLOUD_COVER_MAX=30
VEGETATION_CACHE_TTL_DAYS=30

# Optional provider credentials:
# CLIMATE_ENGINE_API_KEY=
# If you want Climate Engine as the live NDVI source on the server, also set:
# NDVI_PROVIDER=climate_engine
